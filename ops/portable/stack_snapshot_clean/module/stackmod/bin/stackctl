#!/usr/bin/env bash
set -Eeuo pipefail
. "$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)/_common.sh"

cmd="${1:-}"
sub="${2:-}"

case "$cmd:$sub" in
  repos:ls)
    while IFS= read -r repo; do
      [ -n "$repo" ] || continue
      printf '%-12s %s\n' "$repo" "$(repo_path_from_name "$repo")"
    done < <(repo_names)
    ;;
  safe:)
    run_in_repo stack "$STACKMOD_ROOT/ops/bin/security_audit_all.sh"
    ;;
  sync:)
    "$STACKMOD_ROOT/ops/bin/git_sync_all.sh"
    ;;
  secrets_encrypt:)
    "$STACKMOD_ROOT/ops/bin/secrets_encrypt_all.sh"
    ;;
  backup:)
    "$STACKMOD_ROOT/ops/bin/backup_all.sh"
    ;;
  promptpack:)
    "$STACKMOD_ROOT/ops/bin/prompt_pack_all.sh"
    ;;
  md2pdf:)
    "$STACKMOD_ROOT/ops/bin/md_export_all.sh"
    ;;
  security_audit:)
    "$STACKMOD_ROOT/ops/bin/security_audit_all.sh"
    ;;
  ssh_once:)
    "$STACKMOD_ROOT/bin/ssh_once"
    ;;
  *)
    cat <<USAGE
usage:
  stackctl repos ls
  stackctl safe
  stackctl sync
  stackctl secrets_encrypt
  stackctl backup
  stackctl promptpack
  stackctl md2pdf
  stackctl security_audit
  stackctl ssh_once
USAGE
    exit 1
    ;;
esac
